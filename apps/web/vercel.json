{
  "buildCommand": "cd ../.. && pnpm --filter @kassomat/types build && pnpm --filter web build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://kassomat-production.up.railway.app/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
