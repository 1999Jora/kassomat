{
	"appId": "at.kassomat.pos",
	"appName": "Kassomat",
	"webDir": "dist",
	"server": {
		"url": "https://kassomat-pos.vercel.app",
		"androidScheme": "https"
	},
	"plugins": {
		"StatusBar": {
			"style": "DARK",
			"backgroundColor": "#080a0c"
		},
		"Keyboard": {
			"resize": "body",
			"style": "DARK"
		},
		"SplashScreen": {
			"launchShowDuration": 1500,
			"backgroundColor": "#080a0c",
			"androidSplashResourceName": "splash",
			"showSpinner": false
		}
	},
	"android": {
		"minSdkVersion": 26,
		"targetSdkVersion": 34
	}
}
