{
  "name": "api",
  "version": "1.0.0",
  "description": "Kassomat Fastify Backend API",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@kassomat/types": "workspace:*",
    "@kassomat/rksv": "workspace:*",
    "@kassomat/print": "workspace:*",
    "@prisma/client": "^5.10.0",
    "fastify": "^4.26.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/multipart": "^8.1.0",
    "argon2": "^0.31.2",
    "zod": "^3.22.4",
    "bullmq": "^5.4.2",
    "ioredis": "^5.3.2",
    "socket.io": "^4.7.4",
    "pino": "^8.19.0",
    "pino-pretty": "^11.0.0",
    "csv-parse": "^5.5.5",
    "uuid": "^9.0.1",
    "date-fns": "^3.3.1",
    "date-fns-tz": "^3.1.3",
    "node-cron": "^3.0.3",
    "fastify-plugin": "^4.5.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.8",
    "prisma": "^5.10.0",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1",
    "@vitest/coverage-v8": "^1.3.1",
    "supertest": "^6.3.4",
    "@types/supertest": "^6.0.2"
  }
}
