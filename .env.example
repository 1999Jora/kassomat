# ============================================================
# KASSOMAT — Environment Variables
# Kopiere diese Datei zu .env und fülle alle Werte aus
# NIEMALS .env in Git committen!
# ============================================================

# ---- NODE ----
NODE_ENV=development
PORT=3001

# ---- DATABASE (PostgreSQL via Supabase) ----
DATABASE_URL="postgresql://postgres:password@localhost:5432/kassomat?schema=public"
DIRECT_URL="postgresql://postgres:password@localhost:5432/kassomat"

# ---- REDIS ----
REDIS_URL="redis://localhost:6379"

# ---- JWT ----
JWT_SECRET="change-this-to-a-random-256-bit-secret"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="30d"

# ---- ENCRYPTION (AES-256 für API Keys in DB) ----
ENCRYPTION_KEY="change-this-to-a-random-32-byte-hex-string"

# ---- A-TRUST (Cloud HSM Signatur) ----
ATRUST_API_URL="https://hs-abnahme.a-trust.at/openitc/rc150/v3"
ATRUST_API_URL_PROD="https://www.a-trust.at/openitc/rc150/v3"

# ---- FINANZONLINE ----
FINANZONLINE_URL="https://finanzonline.bmf.gv.at"
FINANZONLINE_USER_ID=""
FINANZONLINE_PIN=""

# ---- LIEFERANDO / JET POS API ----
LIEFERANDO_API_URL="https://pos-staging.just-eat.io"
LIEFERANDO_API_URL_PROD="https://pos.just-eat.io"

# ---- WIX ----
WIX_API_URL="https://www.wixapis.com"

# ---- CORS ----
CORS_ORIGIN="http://localhost:5173,http://localhost:5174"

# ---- FRONTEND URLs ----
WEB_APP_URL="http://localhost:5173"
DASHBOARD_URL="http://localhost:5174"
DIGITAL_RECEIPT_URL="https://bon.kassomat.at"

# ---- SMTP (Digitaler Bon per E-Mail) ----
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="bons@kassomat.at"

# ---- STRIPE (Abo-Verwaltung) ----
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_STARTER="price_..."
STRIPE_PRICE_PRO="price_..."
STRIPE_PRICE_BUSINESS="price_..."

# ---- LOGGING ----
LOG_LEVEL="info"
