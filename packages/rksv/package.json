{
  "name": "@kassomat/rksv",
  "version": "1.0.0",
  "description": "RKSV Logik — Hash-Chaining, A-Trust Signatur, DEP, FinanzOnline",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@kassomat/types": "workspace:*",
    "axios": "^1.6.7",
    "zod": "^3.22.4",
    "date-fns": "^3.3.1",
    "date-fns-tz": "^3.1.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  }
}
